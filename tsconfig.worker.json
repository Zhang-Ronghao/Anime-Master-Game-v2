{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "noEmit": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "incremental": false
  },
  "include": ["worker/**/*.ts", "src/types/**/*.ts", "src/lib/id.ts"]
}
